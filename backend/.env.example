# ─────────────────────────────────────────────────────────────
# MediClear AI — backend environment template
# Copy to .env for local dev. For Render, paste each variable
# into the Render web service "Environment" tab instead.
# ─────────────────────────────────────────────────────────────

# ── AI (pick one; both optional) ──────────────────────────────
# Gemini: FREE tier, no credit card. Key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# OpenAI: paid. Key: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ── SECURITY ──────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=change-this-to-a-random-64-char-string-before-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── DATABASE ──────────────────────────────────────────────────
# Local dev (no setup):
DATABASE_URL=sqlite:///./mediclear.db
# Render Postgres: paste the "Internal Database URL" from the DB dashboard.
# Works with either postgres:// or postgresql:// scheme (auto-rewritten).
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# ── APP ───────────────────────────────────────────────────────
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=10
# Comma-separated. For production, set to your actual frontend URL(s), e.g.:
#   CORS_ORIGINS=https://mediclear.vercel.app
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
ENVIRONMENT=development
